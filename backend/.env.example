# ───────────────────────────────────────────────────────────────────────────
# zazenware backend — environment variables
# ───────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values.
# .env is git-ignored. NEVER commit a real .env.
# ───────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=4000

# Database (local Postgres)
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/zazenware

# CORS — comma-separated list of allowed origins (no trailing slash)
# Local dev frontend runs at 5173
CORS_ORIGIN=http://localhost:5173

# Resend (transactional email)
# Get this from https://resend.com after creating an account.
RESEND_API_KEY=

# Email addresses
# In dev, FROM_EMAIL can be onboarding@resend.dev (Resend's sandbox sender).
# In production, FROM_EMAIL becomes orders@zazenware.com after DNS verification.
FROM_EMAIL=onboarding@resend.dev
REPLY_TO_EMAIL=orders@zazenware.com
BCC_EMAIL=orders@zazenware.com
PAYMENTS_EMAIL=payments@zazenware.com

# Operator contact email (printed in confirmation templates)
CONTACT_EMAIL=contact@zazenware.com

# Public base URLs (used in email deep links)
SITE_URL=http://localhost:5173
